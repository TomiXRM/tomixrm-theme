  "tokenColors": [
    {
      "settings": {
        "background": "#2f2b31",
        "foreground": "#f7f4ef"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "comment.block.documentation",
        "comment.line.double-slash.documentation"
      ],
      "settings": {
        "foreground": "#8d8892",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Keywords and operators",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator",
        "keyword.operator.new",
        "storage",
        "storage.modifier",
        "storage.type.modifier"
      ],
      "settings": {
        "foreground": "#ff6b90"
      }
    },
    {
      "name": "Types",
      "scope": [
        "storage.type",
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "entity.other.inherited-class",
        "support.type",
        "support.class",
        "support.type.primitive",
        "meta.type",
        "meta.return-type"
      ],
      "settings": {
        "foreground": "#7dd7e6",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.delimiter"
      ],
      "settings": {
        "foreground": "#939095"
      }
    },
    {
      "name": "Strings and raw blocks",
      "scope": [
        "string",
        "string.quoted",
        "string.template",
        "markup.inline.raw",
        "markup.raw.block",
        "markup.raw.block.fenced"
      ],
      "settings": {
        "foreground": "#e8c15d"
      }
    },
    {
      "name": "Regex and escapes",
      "scope": [
        "constant.character.escape",
        "string.regexp",
        "string.regexp punctuation.definition.string.begin",
        "string.regexp punctuation.definition.string.end",
        "constant.other.symbol"
      ],
      "settings": {
        "foreground": "#b39af5"
      }
    },
    {
      "name": "Constants and numbers",
      "scope": [
        "constant.numeric",
        "constant.language",
        "constant.character",
        "constant.other",
        "variable.other.constant",
        "entity.name.constant",
        "support.constant",
        "support.variable"
      ],
      "settings": {
        "foreground": "#b39af5"
      }
    },
    {
      "name": "Functions and methods",
      "scope": [
        "entity.name.function",
        "entity.name.function.member",
        "support.function",
        "variable.function",
        "meta.function-call",
        "meta.function",
        "meta.method",
        "support.macro"
      ],
      "settings": {
        "foreground": "#9ed06c"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#f7f4ef"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter",
        "parameters variable.function"
      ],
      "settings": {
        "foreground": "#ff9d6b",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Language variables",
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.self",
        "variable.parameter.function.language.special.self",
        "variable.parameter.function.language.special.cls"
      ],
      "settings": {
        "foreground": "#b8b2bc",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Properties",
      "scope": [
        "variable.other.property",
        "variable.other.member",
        "variable.other.property.static",
        "support.type.property-name",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#f7f4ef"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#7dd7e6",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag",
        "meta.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#ff6b90"
      }
    },
    {
      "name": "JSON and object keys",
      "scope": [
        "source.json meta.mapping.key string",
        "source.yaml meta.mapping.key string",
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#f7f4ef"
      }
    },
    {
      "name": "CSS selectors",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.parent-selector-suffix.css",
        "entity.other.attribute-name.css",
        "entity.other.animation-name.css"
      ],
      "settings": {
        "foreground": "#9ed06c"
      }
    },
    {
      "name": "CSS ids and variables",
      "scope": [
        "entity.other.attribute-name.id.css",
        "source.sass variable.other",
        "source.sass variable.sass",
        "source.scss variable.other",
        "source.scss variable.scss",
        "source.scss variable.sass",
        "source.css variable.other",
        "source.less variable.other",
        "source.less variable.other.less",
        "source.less variable.declaration.less"
      ],
      "settings": {
        "foreground": "#ff9d6b",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Preprocessor and decorators",
      "scope": [
        "meta.preprocessor",
        "entity.name.function.preprocessor",
        "entity.name.constant.preprocessor",
        "storage.type.annotation",
        "meta.annotation",
        "meta.decorator",
        "punctuation.definition.annotation"
      ],
      "settings": {
        "foreground": "#b39af5"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#ff6b90",
        "fontStyle": "italic underline"
      }
    },
    {
      "name": "Diff inserted",
      "scope": [
        "markup.inserted"
      ],
      "settings": {
        "foreground": "#9ed06c"
      }
    },
    {
      "name": "Diff deleted",
      "scope": [
        "markup.deleted"
      ],
      "settings": {
        "foreground": "#ff6b90"
      }
    },
    {
      "name": "Diff changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#e8c15d"
      }
    },
    {
      "name": "Markdown headings",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#ff9d6b",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown emphasis",
      "scope": [
        "markup.bold",
        "markup.italic"
      ],
      "settings": {
        "foreground": "#f7f4ef"
      }
    },
    {
      "name": "Markdown quote",
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#b8b2bc",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown links",
      "scope": [
        "string.other.link.title.markdown",
        "string.other.link.description.markdown",
        "markup.underline.link.markdown"
      ],
      "settings": {
        "foreground": "#9ed06c"
      }
    },
    {
      "name": "Markdown punctuation",
      "scope": [
        "punctuation.definition.list.begin.markdown",
        "punctuation.definition.heading.markdown",
        "punctuation.definition.bold.markdown",
        "punctuation.definition.italic.markdown"
      ],
      "settings": {
        "foreground": "#939095"
      }
    }
  ],
  "semanticTokenColors": {
    "comment": {
      "foreground": "#8d8892",
      "italic": true
    },
    "keyword": "#ff6b90",
    "operator": "#ff6b90",
    "string": "#e8c15d",
    "string.escape": "#b39af5",
    "number": "#b39af5",
    "regexp": "#b39af5",
    "function": "#9ed06c",
    "function.defaultLibrary": {
      "foreground": "#9ed06c",
      "italic": true
    },
    "method": "#9ed06c",
    "property": "#f7f4ef",
    "property.defaultLibrary": "#f7f4ef",
    "variable": "#f7f4ef",
    "variable.defaultLibrary": {
      "foreground": "#b8b2bc",
      "italic": true
    },
    "parameter": {
      "foreground": "#ff9d6b",
      "italic": true
    },
    "variable.readonly": "#b39af5",
    "type": {
      "foreground": "#7dd7e6",
      "italic": true
    },
    "type.defaultLibrary": {
      "foreground": "#7dd7e6",
      "italic": true
    },
    "typeParameter": "#ff9d6b",
    "class": "#7dd7e6",
    "interface": "#7dd7e6",
    "struct": "#7dd7e6",
    "enum": "#7dd7e6",
    "enumMember": "#b39af5",
    "namespace": "#7dd7e6",
    "decorator": "#b39af5",
    "macro": "#b39af5"
  }
}
